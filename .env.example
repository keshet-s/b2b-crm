# ============================================================
# B2B CRM — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------

# Environment label: "development" | "staging" | "production"
APP_ENV=development

# Secret key used to sign session tokens / JWTs (generate with: openssl rand -hex 32)
SECRET_KEY=replace-with-a-long-random-string

# ------------------------------------------------------------------
# Database (SQLite — path inside the container)
# ------------------------------------------------------------------

# Absolute path to the SQLite database file inside the container.
# The ./data directory is bind-mounted to /data in docker-compose.yml.
DATABASE_URL=sqlite:////data/crm.db

# ------------------------------------------------------------------
# Anthropic / Claude API
# ------------------------------------------------------------------

# Your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# Claude model to use for AI-assisted features
ANTHROPIC_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------------
# Frontend → Backend connectivity
# ------------------------------------------------------------------

# URL the Streamlit frontend uses to reach the FastAPI backend.
# In docker-compose this is the internal Docker network address.
# In production behind Caddy, set this to the public /api prefix.
BACKEND_URL=http://backend:8000

# ------------------------------------------------------------------
# Production / Caddy (only needed for docker-compose.prod.yml)
# ------------------------------------------------------------------

# Fully-qualified domain name for your EC2 instance.
# Caddy uses this to obtain a Let's Encrypt TLS certificate automatically.
# Example: crm.example.com
DOMAIN=your-domain.example.com

# Email address Let's Encrypt uses for certificate expiry notifications
LETSENCRYPT_EMAIL=ops@example.com

# ------------------------------------------------------------------
# Lead sourcing integrations (add keys as integrations are built)
# ------------------------------------------------------------------

# LinkedIn API credentials (if using LinkedIn data enrichment)
# LINKEDIN_CLIENT_ID=replace-me
# LINKEDIN_CLIENT_SECRET=replace-me

# Apollo.io API key (if using Apollo for lead enrichment)
# APOLLO_API_KEY=replace-me

# Hunter.io API key (if using Hunter for email finding)
# HUNTER_API_KEY=replace-me

# ------------------------------------------------------------------
# Scheduler (APScheduler)
# ------------------------------------------------------------------

# Cron expression for the lead-sourcing background job (default: every 6 hours)
LEAD_SYNC_CRON=0 */6 * * *
